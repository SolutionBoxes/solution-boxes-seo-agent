# Which AI provider powers the chat: "google" (Gemini, free tier, good for testing)
# or "anthropic" (Claude, per instructions/07-development.md — use this for production).
AI_PROVIDER=google

# Optional: override the model used (defaults to gemini-2.5-flash or claude-sonnet-5
# depending on AI_PROVIDER above).
# AI_MODEL=

# Required if AI_PROVIDER=google. Free, no billing required.
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Required if AI_PROVIDER=anthropic. Paid — get one at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Password required to sign in to /admin (chat sidebar + analytics dashboard).
ADMIN_PASSWORD=

# Random secret used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Optional: Redis (Upstash) REST credentials for the /admin/analytics dashboard.
# Without these, the chat still works — the dashboard just shows "not connected".
# Create a database in the Vercel dashboard (Storage tab) or at upstash.com, then
# copy its REST URL/token here.
KV_REST_API_URL=
KV_REST_API_TOKEN=
